# slskd credentials — copy this file to `slskd.env` (same directory) on hl-relay and
# fill it in. `slskd.env` is gitignored; this `.example` is the tracked template.
#
# Soulseek has NO web signup: the account is created at first login. Pick a username +
# password here, and slskd registers them on the network the first time it connects
# (as long as the username isn't already taken — if login bounces, choose another).
# Use a FRESH password you don't reuse elsewhere; it's what protects the account.
SLSKD_SLSK_USERNAME=your_soulseek_username
SLSKD_SLSK_PASSWORD=your_soulseek_password

# Login for the slskd web dashboard (http://hl-relay:5030). Anything you like — this is
# separate from the Soulseek creds above. Change the password from the default.
SLSKD_USERNAME=admin
SLSKD_PASSWORD=change_me_to_something_strong
