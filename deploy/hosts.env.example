# Copy to secrets/hosts.env and set to wherever your Wyoming STT/TTS services listen.
# The code defaults assume a single box (everything on localhost). For a multi-box setup,
# point these at the tailnet/LAN IP:port the services actually bind to.
#
# load order: brain/config.py loads this after ha.env/media.env/ingest.env; a real
# environment variable (e.g. a systemd Environment= line) still overrides it.
HESTIA_WHISPER=127.0.0.1:10300
HESTIA_PIPER=127.0.0.1:10200
