{
  "views": [
    {
      "type": "sections",
      "title": "Home",
      "path": "home",
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading": "Home",
              "icon": "mdi:home"
            },
            {
              "type": "custom:mushroom-chips-card",
              "chips": [
                {
                  "type": "template",
                  "icon": "mdi:power-off",
                  "icon_color": "red",
                  "content": "All Off",
                  "tap_action": {
                    "action": "call-service",
                    "service": "light.turn_off",
                    "target": {
                      "entity_id": [
                        "light.light_living_room_lights",
                        "light.light_kitchen_lights",
                        "light.light_dinning_room_lights",
                        "light.light_outside_lights"
                      ]
                    }
                  }
                },
                {
                  "type": "template",
                  "icon": "mdi:weather-night",
                  "icon_color": "amber",
                  "content": "Calm Home",
                  "tap_action": {
                    "action": "call-service",
                    "service": "scene.turn_on",
                    "target": {
                      "entity_id": "scene.calm_home_default"
                    }
                  }
                }
              ]
            },
            {
              "type": "weather-forecast",
              "entity": "weather.forecast_home",
              "forecast_type": "daily",
              "name": "Home"
            }
          ]
        },
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading": "Living Room",
              "heading_style": "subtitle",
              "icon": "mdi:lightbulb-group"
            },
            {
              "type": "custom:mushroom-light-card",
              "entity": "light.light_living_room_lights",
              "name": "All Living Room",
              "use_brightness": true,
              "show_color_control": false,
              "icon": "mdi:lightbulb-group"
            },
            {
              "type": "custom:mushroom-light-card",
              "entity": "light.tv",
              "name": "TV",
              "use_brightness": true,
              "show_color_control": false
            },
            {
              "type": "media-control",
              "entity": "media_player.smarttv_4k_ffm"
            },
            {
              "type": "thermostat",
              "entity": "climate.living_room_ac"
            }
          ]
        },
        {
