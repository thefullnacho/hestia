    {
      "type": "sections",
      "title": "Garden",
      "path": "garden",
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading": "Soil Moisture",
              "icon": "mdi:sprout"
            },
            {
              "type": "gauge",
              "entity": "sensor.unknown_device_soilmoisture1",
              "name": "Beets",
              "min": 0,
              "max": 100,
              "needle": true,
              "segments": [
                {
                  "from": 0,
                  "color": "#db4437"
                },
                {
                  "from": 40,
                  "color": "#0f9d58"
                },
                {
                  "from": 90,
                  "color": "#4285f4"
                }
              ]
            },
