    {
      "type": "sections",
      "title": "Status",
      "path": "status",
      "sections": [
        {
          "type": "grid",
          "cards": [
            {
              "type": "heading",
              "heading": "CRITICAL INFRASTRUCTURE",
              "heading_style": "title"
            },
            {
              "type": "custom:mushroom-chips-card",
              "chips": [
                {
                  "type": "entity",
                  "entity": "sensor.docker_host_hl_plex_status",
                  "name": "Plex Server",
                  "icon_color": "{% if is_state('sensor.docker_host_hl_plex_status', 'running') %} green\n{% else %} red\n{% endif %}\n",
                  "icon": "mdi:plex",
                  "tap_action": {
                    "action": "navigate",
                    "navigation_path": "http://hl-relay.homelab.local:32004/web"
                  }
                },
                {
                  "type": "entity",
                  "entity": "sensor.docker_host_mosquitto_status",
                  "name": "MQTT Broker",
                  "icon_color": "{% if is_state('sensor.docker_host_mosquitto_status', 'running') %} green\n{% else %} red\n{% endif %}\n",
                  "icon": "mdi:message-settings-variant",
                  "tap_action": {
                    "action": "none"
                  }
                },
                {
                  "type": "entity",
                  "entity": "sensor.docker_host_ecowitt2mqtt_status",
                  "name": "Ecowitt Bridge",
                  "icon_color": "{% if is_state('sensor.docker_host_ecowitt2mqtt_status', 'running') %} green\n{% else %} red\n{% endif %}\n",
                  "icon": "mdi:bridge",
                  "tap_action": {
                    "action": "none"
                  }
                }
              ]
            }
          ]
        }
      ],
      "cards": []
    }
